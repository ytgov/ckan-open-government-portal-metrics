# Environmental variables for YG CKAN actions
# Replace these with the applicable URLs below (in quotes) prior to running load.R

# Instance URL
ckan_url="https://open.yukon.ca/"

# CKAN API token
ckan_api_token=""

# Matomo auth token to make API requests to analytics.gov.yk.ca (on-premise/VPN only)
matomo_auth_token=""

# Earliest date to request results from (e.g. "2023-01-01")
matomo_earliest_date="2021-01-01"

# Package ID for the open government portal metrics dataset
ckan_open_government_portal_metrics_package_id="open-government-portal-metrics"
